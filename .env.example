# ── Core ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_32_byte_hex_string

# ── Vertex AI (Gemini) ───────────────────────────────────────────
# Required for FastAPI runtime in backend/main.py
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_DEFAULT_MODEL=gemini-2.0-flash

# ── Database ──────────────────────────────────────────────────────
# SQLite (local dev / single instance):
DATABASE_URL=sqlite:///nova_fastapi.db
#
# PostgreSQL (Cloud SQL on GKE/Cloud Run — recommended for production):
# DATABASE_URL=postgresql+psycopg2://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
#
# PostgreSQL via TCP (non-Cloud-Run):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── Google OAuth ─────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorised redirect URI: https://<your-app>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────
# github.com/settings/applications/new
# Callback URL: https://<your-app>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional demo defaults ────────────────────────────────────────
DEMO_USER_EMAIL=user@nova.local
DEMO_USER_NAME=Nova User
