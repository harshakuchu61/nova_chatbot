# ── Core ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_32_byte_hex_string

# ── OpenAI ───────────────────────────────────────────────────────
# Server-level API key (all users share this unless they set their own in Settings).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────
# SQLite (local dev / single instance):
DATABASE_URL=sqlite:///nova.db
#
# PostgreSQL (Cloud SQL on GCP Cloud Run — recommended for production):
# DATABASE_URL=postgresql+psycopg2://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
#
# PostgreSQL via TCP (non-Cloud-Run):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── Google OAuth ─────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorised redirect URI: https://<your-app>/google/authorized
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────
# github.com/settings/applications/new
# Callback URL: https://<your-app>/github/authorized
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Local dev only (HTTP) ─────────────────────────────────────────
# Allows OAuth over plain HTTP — NEVER set this in production
OAUTHLIB_INSECURE_TRANSPORT=1
